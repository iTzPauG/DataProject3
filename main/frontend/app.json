{
  "expo": {
    "name": "WHIM",
    "slug": "whim",
    "version": "1.0.0",
    "scheme": "whim",
    "orientation": "portrait",
    "icon": "./assets/whim-logo-new.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/whim-logo-new.png",
      "resizeMode": "contain",
      "backgroundColor": "#4AABB3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.whim.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/whim-logo-new.png",
        "backgroundColor": "#4AABB3"
      },
      "package": "com.whim.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/whim-logo-new.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
